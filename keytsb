-- // TSB MECHANICS ENGINE // SUPREME (MODIFIED - BACKDASH SUPPORT)

local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local DashSettings = {
    AnimSpeedMultiplier = 5,
    DashDistance = 1,
    DashDuration = 0.2,
    DashSmoothing = 0.5,
    DashCooldown = 1.6
}

local LastDashTime = 0
local NextAllowedDash = 0 

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    if input.KeyCode == Enum.KeyCode.Q then
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if not char or not hum or not root then return end
        
        if os.clock() < NextAllowedDash then return end
        
        -- // Determine if moving or backdashing
        if hum.MoveDirection.Magnitude > 0 then
            LastDashTime = os.clock() + DashSettings.DashDuration
            NextAllowedDash = os.clock() + DashSettings.DashCooldown
        end
    end
end)

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not char or not root or not hum then return end
    
    local animator = hum:FindFirstChildOfClass("Animator")
    if animator then
        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
            if string.find(string.lower(track.Animation.Name), "dash") then
                track:AdjustSpeed(DashSettings.AnimSpeedMultiplier)
            end
        end
    end
    
    if (os.clock() < LastDashTime) then
        local moveDir = hum.MoveDirection
        if (moveDir.Magnitude > 0) then
            -- // This applies the boost in the direction of your movement, 
            -- // effectively boosting both forward and backdash.
            local targetPos = root.CFrame + (moveDir.Unit * DashSettings.DashDistance)
            root.CFrame = root.CFrame:Lerp(targetPos, DashSettings.DashSmoothing)
        end
    end
end)
